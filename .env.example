# Copie para .env e ajuste se necessário

ENGINE_PORT=8000

# PostgreSQL (banco de dados)
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app
POSTGRES_PORT=5433 

# URL para o PRISMA LOCAL (rodando no Windows) conseguir fazer as migrações
DATABASE_URL=postgresql://app:app@localhost:5433/app

# Redis (fila / pool de desafios)
REDIS_PORT=6379
REDIS_QUEUE_URL=redis://redis:6379/0

# Pool de desafios (orquestrador)
POOL_MIN=3
POOL_TARGET=10

# Circuit breaker (Opossum) — chamadas RPOP/LLEN do pool no Redis
REDIS_POOL_CIRCUIT_TIMEOUT_MS=3000
REDIS_POOL_CIRCUIT_RESET_MS=30000
REDIS_POOL_CIRCUIT_ERROR_THRESHOLD_PERCENTAGE=50
REDIS_POOL_CIRCUIT_VOLUME_THRESHOLD=5

# Rate limit por IP (cliente) — janela no Redis
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_SEC=60
TRUST_PROXY=true

AI_WORKER_INTERVAL_SEC=30

REFILL_STREAM_KEY=stream:refill_jobs
POOL_KEY_PREFIX=pool:ad:

# Circuit Breaker e Retry
AI_MAX_RETRIES=3
AI_CIRCUIT_FAIL_MAX=5
AI_CIRCUIT_RESET_TIMEOUT_SEC=60
REDIS_STREAM_BLOCK_MS=5000

GEMINI_API_KEY="Sua API key aqui"

# --- Infra: BullMQ (Engine → Redis Stream), descarte de carga, DLQ, métricas ---
REFILL_BULLMQ_QUEUE_NAME=refill-to-stream
BULLMQ_PREFIX=bull
REFILL_WORKER_CONCURRENCY=8
REFILL_QUEUE_ATTEMPTS=3
REFILL_QUEUE_BACKOFF_MS=1500
LOAD_SHED_ENABLED=true
LOAD_SHED_MAX_WAITING=500
LOAD_SHED_CONCURRENT_MAX=0
LOAD_SHED_SLOT_TTL_SEC=120
AI_DLQ_LIST_KEY=dlq:ai:refill

# Painel (Docker): Vite no serviço `panel`
PANEL_PORT=5173
# URL da Engine **no teu browser** (host). Se ENGINE_PORT=8010, usa http://localhost:8010
VITE_API_BASE_URL=http://localhost:8000