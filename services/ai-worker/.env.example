DATABASE_URL=postgresql+asyncpg://app:app@localhost:5432/app

REDIS_QUEUE_URL=redis://localhost:6379/0
REFILL_STREAM_KEY=stream:refill_jobs
REFILL_DLQ_STREAM_KEY=stream:refill_dlq
POOL_KEY_PREFIX=pool:ad:

AI_MAX_RETRIES=3
AI_RETRY_MIN_SEC=1
AI_RETRY_MAX_SEC=60
AI_RETRY_BACKOFF_MULTIPLIER=1
AI_CIRCUIT_FAIL_MAX=5
AI_CIRCUIT_RESET_TIMEOUT_SEC=60
REDIS_STREAM_BLOCK_MS=5000

# DLQ (lista Redis) — alinhado com Engine /metrics
AI_DLQ_LIST_KEY=dlq:ai:refill

GEMINI_API_KEY="Sua API key aqui"