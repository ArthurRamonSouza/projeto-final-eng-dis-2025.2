{
    "name": "engine",
    "version": "0.1.0",
    "private": true,
    "packageManager": "pnpm@9.15.9",
    "type": "module",
    "scripts": {
        "build": "prisma generate && tsc -p tsconfig.build.json",
        "start": "node dist/server.js",
        "dev": "tsx watch src/server.ts",
        "db:generate": "prisma generate",
        "db:migrate": "prisma migrate dev",
        "db:push": "prisma db push",
        "db:studio": "prisma studio",
        "lint": "eslint .",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "check": "pnpm run lint && pnpm run format:check && pnpm run build"
    },
    "dependencies": {
        "@prisma/adapter-pg": "^7.5.0",
        "@prisma/client": "^7.5.0",
        "cors": "^2.8.6",
        "dotenv": "^17.3.1",
        "express": "^5.2.1",
        "pg": "^8.20.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.17.0",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/node": "^22.19.15",
        "@types/pg": "^8.20.0",
        "eslint": "^9.17.0",
        "eslint-config-prettier": "^9.1.0",
        "prettier": "^3.4.2",
        "prisma": "^7.5.0",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.18.1"
    },
    "engines": {
        "node": ">=20"
    }
}
